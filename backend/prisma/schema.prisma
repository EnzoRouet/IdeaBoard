// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Idea {
  id        Int      @id @default(autoincrement())
  title     String
  content   String
  author    String
  likes     Int      @default(0)
  createdAt DateTime @default(now())
}